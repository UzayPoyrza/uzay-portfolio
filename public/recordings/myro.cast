[0.102, "o", "\u001b[1;5H\u001b[1m\u001b[38;2;100;200;200;49mD\u001b[1;9Hecret Passwords\u001b[4;3H\u001b[22m\u001b[39;49mOn\u001b[4;7Hunkn\u001b[4;12Hwn \u001b[4;16Hacker w\u001b[4;24Hnts to get the admin's password of AtForc\u001b[4;66Hs test\u001b[4;74Hg system, \u001b[5;1Hto get problems\u001b[5;17Hfrom the next contest. To achieve that, he sneaked\u001b[5;68Hinto \u001b[5;74Hh\u001b[5;76H   \u001b[6;1Hadministrator's off\u001b[6;21Hce and stole a p\u001b[6;38Hece of paper with a list\u001b[6;63Hof \u001b[38;2;125;207;255;49mn\u001b[39;49m passwords \u2014    \u001b[7;1Hstrings, consis\u001b[7;17Hs\u001b[7;19Hof \u001b[7;23Hmall\u001b[7;28HLatin\u001b[7;34Hletters.\u001b[8;3HHacker went h\u001b[8;17Hme and started preparing to\u001b[8;45Hhack AtForces. H\u001b[8;62H found\u001b[8;69Htha\u001b[8;73H the \u001b[8;79Hystem\u001b[9;1Hcontains only passw\u001b[9;21Hrds from \u001b[9;32He stol\u001b[9;39Hn\u001b[9;43Hst and\u001b[9;52Hat the system \u001b[9;67Hetermines the\u001b[9;81H  \u001b[10;1Hequivalenc\u001b[10;13Hof \u001b[10;17Hhe pas\u001b[10;24Hwords \u001b[38;2;125;207;255;49ma\u001b[10;32H\u001b[39;49mand \u001b[38;2;125;207;255;49mb\u001b[39;49m as follows:      \u001b[10;56H   \u001b[10;60H  \u001b[10;63H       \u001b[10;71H     \u001b[10;77H  \u001b[10;80H    \u001b[11;1H    -\u001b[11;7Htwo\u001b[11;11Hpasswords\u001b[11;21H"]
[0.0, "o", "\u001b[38;2;125;207;255;49ma\u001b[11;23H\u001b[39;49mand\u001b[11;27H\u001b[38;2;125;207;255;49mb\u001b[11;29H\u001b[39;49mare\u001b[11;33Hequivalent\u001b[11;44Hif\u001b[11;47Hthere\u001b[11;53His\u001b[11;56Ha\u001b[11;58Hletter,\u001b[11;66Hthat\u001b[11;71Hexists\u001b[11;78Hin\u001b[11;81Hboth\u001b[12;1H\u001b[38;2;125;207;255;49ma\u001b[12;3H\u001b[39;49mand \u001b[38;2;125;207;255;49mb\u001b[39;49m;       \u001b[12;17H    \u001b[12;22H    \u001b[12;27H       \u001b[12;35H     \u001b[12;41H    \u001b[12;46H   \u001b[12;50H      \u001b[12;57H  \u001b[12;60H   \u001b[12;64H     \u001b[12;70H     \u001b[12;76H   \u001b[12;80H  \u001b[14;1H\u001b[38;5;8;49m \u001b[14;3H\u001b[38;5;0;48;5;15m \u001b[38;5;15;49m                 \u001b[14;41H                                            \u001b[15;1H\u001b[38;5;8;49m \u001b[15;3H\u001b[38;5;15;49m            \u001b[15;41H                                            \u001b[16;41H                                            \u001b[17;41H                                            \u001b[18;1H\u001b[38;5;8;49m  \u001b[38;5;15;49m                                                                                  \u001b[19;1H\u001b[38;5;8;49m  \u001b[38;5;15;49m                                                                               "]
