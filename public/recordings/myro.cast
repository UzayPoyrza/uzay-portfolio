[0.109, "o", "\u001b[1;3H\u001b[38;2;160;130;220;49m\u25c6\u001b[1;5H\u001b[1m\u001b[38;2;100;200;200;49mC. Shawarma Tent\u001b[2;3H\u001b[22m\u001b[39;49m  \u001b[38;5;8;49m\u23f1\u001b[38;5;7;49m 1 second\u001b[2;16H\u001b[38;5;8;49m\u25cf\u001b[38;5;7;49m 256 megabytes\u001b[4;1H\u001b[39;49m  The map of the capital of Berland can be viewed on the infinite coordinate plane. \u001b[5;1HEach point with integer coordinates\u001b[5;37Hcontains\u001b[5;46Ha\u001b[5;48Hbuilding,\u001b[5;58Hand\u001b[5;62Hthere\u001b[5;68Hare\u001b[5;72Hstreets\u001b[6;1Hconnecting\u001b[6;12Hevery\u001b[6;18Hbuilding\u001b[6;27Hto\u001b[6;30Hfour\u001b[6;35Hneighbouring\u001b[6;48Hbuildings.\u001b[6;59HAll\u001b[6;63Hstreets\u001b[6;71Hare\u001b[6;75Hparallel\u001b[7;1Hto the\u001b[7;8Hcoordinate\u001b[7;19Haxes.\u001b[8;3HThe main school\u001b[8;19Hof\u001b[8;22Hthe\u001b[8;26Hcapital\u001b[8;34His\u001b[8;37Hlocated\u001b[8;45Hin\u001b[8;48H\u001b[38;2;125;207;255;49m(s\u2093, s_y)\u001b[39;49m.\u001b[8;59HThere\u001b[8;65Hare\u001b[8;69H\u001b[38;2;125;207;255;49mn\u001b[8;71H\u001b[39;49mstudents\u001b[9;1Hattending this\u001b[9;16Hschool,\u001b[9;24Hthe\u001b[9;28H\u001b[38;2;125;207;255;49mi\u001b[39;49m-th\u001b[9;33Hof\u001b[9;36Hthem\u001b[9;41Hlives\u001b[9;47Hin\u001b[9;50Hthe\u001b[9;54Hhouse\u001b[9;60Hlocated\u001b[9;68Hin\u001b[9;71H\u001b[38;2;125;207;255;49m(x\u1d62, y\u1d62)\u001b[39;4"]
